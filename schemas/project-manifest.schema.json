{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "captain-project-manifest.schema.json",
  "title": "Captain OS Project Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "captainOsVersion",
    "mode",
    "projectName",
    "runtimes",
    "paths",
    "evidencePolicy"
  ],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "const": "captain-project.v1" },
    "captainOsVersion": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["shadow", "advisory", "selected_blocking"] },
    "ownerName": { "type": "string" },
    "projectName": { "type": "string", "minLength": 1 },
    "tracking": { "type": "string" },
    "runtimes": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "reviewers": { "type": "array", "items": { "type": "string" } },
        "optionalJudges": { "type": "array", "items": { "type": "string" } }
      }
    },
    "paths": {
      "type": "object",
      "required": ["repairLedger", "labRuns", "brain", "processDocs"],
      "additionalProperties": { "type": "string" }
    },
    "managedBlocks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "protectedPaths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "swarmRuntime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "defaultExecutionModel": {
          "type": "string",
          "enum": ["single_lane", "parallel_lane_swarm"]
        },
        "captainRole": {
          "type": "string",
          "enum": ["orchestrator", "orchestrator_and_worker"]
        },
        "laneMemory": {
          "type": "string",
          "enum": ["optional", "required_for_tier2_plus", "required_for_all_packeted_lanes"]
        },
        "activeLaneTarget": {
          "type": "object",
          "properties": {
            "min": { "type": "number", "minimum": 0 },
            "max": { "type": "number", "minimum": 1 }
          }
        },
        "maxCaptainChildren": { "type": "number", "minimum": 1 },
        "standingReviewLane": { "type": "string" },
        "starpomLane": { "type": "string" }
      }
    },
    "operatorDecisionInterrupt": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "appliesTo": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ownerChoicesRequired": {
          "type": "object",
          "properties": {
            "min": { "type": "number", "minimum": 2 },
            "max": { "type": "number", "maximum": 3 }
          }
        },
        "defaultOnBlocker": {
          "type": "string",
          "enum": ["blocked_waiting_owner"]
        },
        "adjacentPlanningDefaultAllowed": { "const": false },
        "adjacentPlanningBypass": {
          "type": "object",
          "properties": {
            "requiresOwnerApproval": { "const": true },
            "requiresTimebox": { "const": true },
            "requiresVisibleWarning": { "const": true }
          }
        },
        "blockedButContinuingBudget": {
          "type": "object",
          "properties": {
            "maxPlanningOnlyPackets": { "type": "number", "maximum": 2 },
            "maxHoursWithoutOwnerDecision": { "type": "number", "maximum": 2 }
          }
        },
        "seoProductionSuccessEvidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "http200SuccessAllowed": { "const": false }
      }
    },
    "evidencePolicy": {
      "type": "object",
      "required": [
        "writeArtifactsToProject",
        "writeArtifactsToOsRepo",
        "globalBlockingEnabled",
        "productAcceptedFullAllowed"
      ],
      "properties": {
        "writeArtifactsToProject": { "const": true },
        "writeArtifactsToOsRepo": { "const": false },
        "requireScrubBeforePromotionToCore": { "type": "boolean" },
        "globalBlockingEnabled": { "const": false },
        "productAcceptedFullAllowed": { "const": false }
      }
    }
  }
}
